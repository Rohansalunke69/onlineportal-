<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Online Assignment Submission Portal — submit, track, and grade assignments seamlessly.">
  <title><%= typeof title !== 'undefined' ? title : 'Assignment Portal' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand">
      <a href="/">📚 AssignPortal</a>
    </div>
    <div class="nav-links">
      <% if (user) { %>
        <% if (user.role === 'student') { %>
          <a href="/student/dashboard">Dashboard</a>
        <% } else { %>
          <a href="/teacher/dashboard">Dashboard</a>
          <a href="/teacher/assignment/new">+ New Assignment</a>
        <% } %>
        <span class="nav-user"><%= user.name %> · <%= user.role %></span>
        <a href="/logout" class="btn-link">Logout</a>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
    </div>
  </nav>
  <main class="container">
