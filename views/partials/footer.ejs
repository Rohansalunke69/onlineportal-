<% if (user) { %>
    </main>
    <footer class="footer">
      AssignPortal &mdash; Academic Assignment Hub &copy; <%= new Date().getFullYear() %>
    </footer>
  </div><!-- /.main-content -->
</div><!-- /.app-layout -->
<% } else { %>
</div><!-- /.auth-page -->
<% } %>

<script>
/* ── Dark Mode ── */
(function () {
  const root = document.documentElement;
  const saved = localStorage.getItem('ap-theme') || 'light';
  root.setAttribute('data-theme', saved);
  function syncBtn() {
    const isDark = root.getAttribute('data-theme') === 'dark';
    const icon  = document.getElementById('themeIcon');
    const label = document.getElementById('themeLabel');
    if (icon)  icon.textContent  = isDark ? '☀️' : '🌙';
    if (label) label.textContent = isDark ? 'Light' : 'Dark';
  }
  syncBtn();
  document.getElementById('themeToggle')?.addEventListener('click', function () {
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('ap-theme', next);
    syncBtn();
  });
})();

/* ── Toast Notifications ── */
function showToast(message, type) {
  type = type || 'success';
  const icons = { success: '✅', error: '❌', info: 'ℹ️' };
  const container = document.getElementById('toastContainer');
  if (!container) return;
  const toast = document.createElement('div');
  toast.className = 'toast toast-' + type;
  toast.innerHTML =
    '<span class="toast-icon">' + icons[type] + '</span>' +
    '<span class="toast-msg">' + message + '</span>' +
    '<button class="toast-close" onclick="dismissToast(this.parentElement)">✕</button>';
  container.appendChild(toast);
  setTimeout(function () { dismissToast(toast); }, 4500);
}
function dismissToast(el) {
  if (!el || el.classList.contains('toast-out')) return;
  el.classList.add('toast-out');
  setTimeout(function () { el.remove(); }, 320);
}
if (window.__FLASH__) {
  showToast(window.__FLASH__.message, window.__FLASH__.type);
}

/* ── Sidebar (mobile) ── */
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('sidebarOverlay');
const hamburger = document.getElementById('hamburger');

function openSidebar() {
  sidebar?.classList.add('open');
  overlay?.classList.add('visible');
  document.body.style.overflow = 'hidden';
}
function closeSidebar() {
  sidebar?.classList.remove('open');
  overlay?.classList.remove('visible');
  document.body.style.overflow = '';
}
hamburger?.addEventListener('click', openSidebar);
overlay?.addEventListener('click', closeSidebar);

/* ── Logout confirm ── */
document.getElementById('logoutLink')?.addEventListener('click', function(e) {
  if (!confirm('Are you sure you want to logout?')) e.preventDefault();
});

/* ── Drag & Drop File Upload ── */
document.querySelectorAll('.file-drop-zone').forEach(function (zone) {
  const input = zone.querySelector('input[type="file"]');
  const nameEl = zone.querySelector('.file-name-display');

  if (input) {
    input.addEventListener('change', function () {
      if (this.files.length && nameEl) {
        nameEl.textContent = '📎 ' + this.files[0].name;
        nameEl.classList.add('visible');
      }
    });
  }
  ['dragenter', 'dragover'].forEach(function (ev) {
    zone.addEventListener(ev, function (e) { e.preventDefault(); zone.classList.add('drag-over'); });
  });
  ['dragleave', 'drop'].forEach(function (ev) {
    zone.addEventListener(ev, function (e) {
      e.preventDefault();
      zone.classList.remove('drag-over');
      if (ev === 'drop' && input) {
        input.files = e.dataTransfer.files;
        if (e.dataTransfer.files.length && nameEl) {
          nameEl.textContent = '📎 ' + e.dataTransfer.files[0].name;
          nameEl.classList.add('visible');
        }
      }
    });
  });
});

/* ── Countdown Timers ── */
document.querySelectorAll('[data-due-date]').forEach(function (el) {
  function update() {
    const due = new Date(el.getAttribute('data-due-date'));
    const now = new Date();
    const diff = due - now;
    const valEl = el.querySelector('.countdown-value');
    if (!valEl) return;
    if (diff <= 0) {
      valEl.textContent = 'Past due';
      el.className = el.className.replace(/urgency-\w+/g, '') + ' urgency-overdue';
      return;
    }
    const days    = Math.floor(diff / 86400000);
    const hours   = Math.floor((diff % 86400000) / 3600000);
    const minutes = Math.floor((diff % 3600000) / 60000);
    const seconds = Math.floor((diff % 60000) / 1000);
    let text = '';
    if (days > 0)    text = days + 'd ' + hours + 'h remaining';
    else if (hours > 0) text = hours + 'h ' + minutes + 'm remaining';
    else             text = minutes + 'm ' + seconds + 's remaining';
    valEl.textContent = text;
  }
  update();
  setInterval(update, 1000);
});

/* ── Character counter ── */
document.querySelectorAll('[data-maxlength]').forEach(function (el) {
  const max = parseInt(el.getAttribute('data-maxlength'));
  const counter = document.getElementById(el.id + '-counter');
  if (!counter) return;
  function upd() { counter.textContent = el.value.length + ' / ' + max; }
  el.addEventListener('input', upd);
  upd();
});

/* ── Progress bars animate ── */
document.querySelectorAll('.progress-fill[data-pct]').forEach(function (el) {
  const pct = parseFloat(el.getAttribute('data-pct')) || 0;
  el.style.width = '0%';
  setTimeout(function () { el.style.width = Math.min(pct, 100) + '%'; }, 80);
});

/* ── Student dashboard search/filter ── */
const searchInput  = document.getElementById('searchInput');
const statusFilter = document.getElementById('statusFilter');
const subjectFilter = document.getElementById('subjectFilter');
const assignCards  = document.querySelectorAll('.asgn-card[data-title]');

function filterCards() {
  if (!assignCards.length) return;
  const q       = (searchInput  ? searchInput.value.toLowerCase()  : '');
  const status  = (statusFilter ? statusFilter.value.toLowerCase() : '');
  const subject = (subjectFilter ? subjectFilter.value.toLowerCase() : '');
  assignCards.forEach(function (card) {
    const title   = (card.getAttribute('data-title')   || '').toLowerCase();
    const subj    = (card.getAttribute('data-subject') || '').toLowerCase();
    const st      = (card.getAttribute('data-status')  || '').toLowerCase();
    const matchQ  = !q      || title.includes(q)    || subj.includes(q);
    const matchSt = !status  || st.includes(status);
    const matchSu = !subject || subj.includes(subject);
    card.closest('.asgn-card-wrapper')
      ? (card.closest('.asgn-card-wrapper').style.display = (matchQ && matchSt && matchSu) ? '' : 'none')
      : (card.style.display = (matchQ && matchSt && matchSu) ? '' : 'none');
  });
}

searchInput?.addEventListener('input', filterCards);
statusFilter?.addEventListener('change', filterCards);
subjectFilter?.addEventListener('change', filterCards);
</script>
</body>
</html>
