<% var title = 'Teacher Dashboard' %>
<% var activePage = 'dashboard' %>
<%- include('../partials/header') %>

<%
  const totalSubmissions = assignments.reduce((sum, a) => sum + (a.submissionCount || 0), 0);
  const totalGraded      = assignments.reduce((sum, a) => sum + (a.gradedCount || 0), 0);
  const now              = new Date();
  const activeCount      = assignments.filter(a => new Date(a.dueDate) >= now).length;
%>

<!-- Page header -->
<div class="page-header">
  <div>
    <h1 class="page-header-title">My Assignments</h1>
    <p class="page-header-sub">Welcome back, <strong><%= user.name %></strong> — manage your classroom</p>
  </div>
  <a href="/teacher/assignment/new" class="btn btn-primary">➕ New Assignment</a>
</div>

<!-- KPI Cards -->
<div class="kpi-grid stagger">
  <div class="kpi-card">
    <div class="kpi-icon kpi-icon-indigo">📚</div>
    <div class="kpi-body">
      <div class="kpi-value"><%= assignments.length %></div>
      <div class="kpi-label">Assignments</div>
    </div>
  </div>
  <div class="kpi-card">
    <div class="kpi-icon kpi-icon-amber">🟢</div>
    <div class="kpi-body">
      <div class="kpi-value"><%= activeCount %></div>
      <div class="kpi-label">Active</div>
    </div>
  </div>
  <div class="kpi-card">
    <div class="kpi-icon kpi-icon-green">📤</div>
    <div class="kpi-body">
      <div class="kpi-value"><%= totalSubmissions %></div>
      <div class="kpi-label">Submissions</div>
    </div>
  </div>
  <div class="kpi-card">
    <div class="kpi-icon kpi-icon-purple">✅</div>
    <div class="kpi-body">
      <div class="kpi-value"><%= totalGraded %></div>
      <div class="kpi-label">Graded</div>
    </div>
  </div>
</div>

<% if (assignments.length === 0) { %>
  <div class="empty-state">
    <div class="empty-state-icon">📝</div>
    <h3>No assignments yet</h3>
    <p>Click <strong>New Assignment</strong> to create your first one.</p>
    <br>
    <a href="/teacher/assignment/new" class="btn btn-primary">➕ Create Assignment</a>
  </div>
<% } else { %>

<div class="section-title">All Assignments</div>

<div class="teacher-asgn-list stagger">
  <% assignments.forEach(function(a) {
    const isOverdue  = new Date(a.dueDate) < now;
    const pct        = a.submissionCount > 0 ? (a.gradedCount / a.submissionCount) * 100 : 0;
    const subPct     = 0; // we don't track total student count here, so show graded / submitted
  %>
  <div class="teacher-asgn-card">
    <div class="teacher-asgn-header">
      <div style="flex:1;min-width:0;">
        <div class="teacher-asgn-title"><%= a.title %></div>
        <div class="teacher-asgn-sub">
          📖 <%= a.subject %> &nbsp;·&nbsp;
          📅 Due <%= new Date(a.dueDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
          <% if (isOverdue) { %><span class="badge badge-missed" style="margin-left:6px;">Closed</span><% } %>
        </div>
      </div>
      <div class="teacher-asgn-actions">
        <a href="/teacher/assignment/<%= a._id %>/submissions" class="btn btn-secondary btn-sm">📋 Submissions (<%= a.submissionCount %>)</a>
        <a href="/teacher/assignment/<%= a._id %>/edit" class="btn btn-secondary btn-sm">✏️ Edit</a>
        <form action="/teacher/assignment/<%= a._id %>/delete" method="POST" class="inline-form"
              onsubmit="return confirm('Delete \'<%= a.title %>\' and all its submissions?')">
          <button type="submit" class="btn btn-danger btn-sm">🗑️</button>
        </form>
      </div>
    </div>

    <% if (a.submissionCount > 0) { %>
    <div class="progress-wrap">
      <div class="progress-label">
        <span>Graded <%= a.gradedCount %> / <%= a.submissionCount %> submissions</span>
        <span><%= Math.round(pct) %>%</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill <%= pct >= 100 ? 'progress-full' : '' %>"
             data-pct="<%= pct %>"></div>
      </div>
    </div>
    <% } else { %>
    <div style="font-size:0.78rem;color:var(--text-muted);margin-top:4px;">No submissions yet</div>
    <% } %>
  </div>
  <% }) %>
</div>

<% } %>

<%- include('../partials/footer') %>
