<% var title = 'Teacher Dashboard' %>
<%- include('../partials/header') %>

<div class="header-row">
  <div>
    <h2>My Assignments</h2>
    <p class="subtitle">Welcome, <%= user.name %>! Manage the assignments you've created.</p>
  </div>
  <a href="/teacher/assignment/new" class="btn btn-primary">+ New Assignment</a>
</div>

<% if (assignments.length === 0) { %>
  <p class="empty-state">You haven't created any assignments yet. Click "New Assignment" to get started.</p>
<% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Subject</th>
        <th>Due Date</th>
        <th>Submissions</th>
        <th>Graded</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% assignments.forEach(a => { %>
        <tr>
          <td><%= a.title %></td>
          <td><%= a.subject %></td>
          <td><%= new Date(a.dueDate).toLocaleString() %></td>
          <td><%= a.submissionCount %></td>
          <td><%= a.gradedCount %></td>
          <td class="actions">
            <a href="/teacher/assignment/<%= a._id %>/submissions" class="btn btn-small">Submissions</a>
            <a href="/teacher/assignment/<%= a._id %>/edit" class="btn btn-small">Edit</a>
            <form action="/teacher/assignment/<%= a._id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('Delete this assignment and all its submissions?');">
              <button type="submit" class="btn btn-small btn-danger">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('../partials/footer') %>
